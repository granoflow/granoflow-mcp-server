{
  "name": "@granoflow/mcp-server",
  "version": "0.1.0",
  "description": "MCP server for Granoflow: exposes the Local HTTP API as tools for AI agents, IDEs, and automation.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/granoflow/granoflow-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/granoflow/granoflow-mcp-server/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/granoflow/granoflow-mcp-server.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "granoflow-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest run",
    "check": "npm run format && npm run lint && npm run build && npm run test",
    "prepublishOnly": "npm run check"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "vitest": "^4.0.14"
  }
}
