    },
    {
      "id": "chrome_side_rail_icons",
      "family": "rail",
      "axes": ["position:side", "density:icons"],
      "plain_label_hint": "侧轨图标导航"
    },
    {
      "id": "chrome_side_rail_labels",
      "family": "rail",
      "axes": ["position:side", "density:icons_labels"],
